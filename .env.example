SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price
PRICE_EUR_CENTS=3900
CURRENCY=eur

# Token policy
TOKEN_EXPIRY_HOURS=48
MAX_TOKEN_VIEWS=5
TOKEN_PEPPER=change-me-long-random

# Worker auth
WORKER_SECRET=change-me
HMAC_MAX_SKEW_SECONDS=300
NONCE_TTL_SECONDS=600

# Job lease
JOB_LEASE_SECONDS=180

# OpenAI (optional; without it worker runs in fallback mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=900
MAX_OPENAI_TOKENS=1200
MAX_OPENAI_COST_CENTS=12
OPENAI_COST_PER_1K_TOKENS_CENTS=2

# Google Places
GOOGLE_PLACES_API_KEY=
MAX_PLACES_CALLS=5
PLACES_CACHE_TTL_SECONDS=604800  # 7 days (server caps at 30 days)

# Retention policy
RETENTION_DAYS=30

# Public base url (prod)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional (recommended): Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin (Ops page + cleanup endpoint)
ADMIN_SECRET=change-me


# Base URL (recommended in production to avoid relying on Origin header)
NEXT_PUBLIC_BASE_URL="https://your-domain.com"

# Global daily caps (0 disables). Helps prevent abuse & runaway costs.
MAX_DAILY_OPENAI_CENTS="0"
MAX_DAILY_PLACES_CALLS="0"

# V16 viewer session (required for detail access)
VIEWER_SESSION_SECRET=change_me_long_random

# V16 preview (optional)
PREVIEW_CACHE_HOURS=24
PREVIEW_REGION=

# Worker behavior
BETA_FAIL_OPEN_DAILY=false
